# Knowledge Pipeline v5.0.0
# Copy this file to .env and fill in your values

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.3-codex

# Notion
NOTION_TOKEN=your_notion_token_here
NOTION_SOURCES_DB=your_notion_sources_database_id_here
NOTION_CLIENTS_DB=your_notion_clients_database_id_here

# Google Drive — use ONE of these auth methods:
# Option A: Service account key
GOOGLE_APP_CREDENTIALS=path/to/your/service-account-key.json
# Option B: OAuth desktop flow (create OAuth client ID in Cloud Console)
GOOGLE_OAUTH_CLIENT_SECRET=client_secret.json
GOOGLE_OAUTH_TOKEN=token.json
# Drive folder ID (from the folder URL)
DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Gmail ingest (optional — only needed for python -m src.ingest)
GMAIL_LABEL_SOURCE=knowledge-pipeline
GMAIL_LABEL_PROCESSED=pipeline-processed

# Enrichment
ENRICHMENT_MAX_ITERATIONS=50
